# MongoDB Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jci-ledger

# Cloudinary (pour le stockage des images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret (générer avec: openssl rand -base64 32)
JWT_SECRET=your_secure_jwt_secret_key_here

# Google reCAPTCHA
# Pour le développement local, utilisez la clé de test Google (fonctionne sur localhost)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LcFoTotAAAAAMHdVfR0I0ue0IUSrXjYG2vZPSt7
RECAPTCHA_SECRET_KEY=6LcFoTotAAAAABO5Havzxz7Z8INe1bMpzrNiaD0A

# Pour la production, créez votre propre clé sur https://www.google.com/recaptcha/admin
# et ajoutez votre domaine (ex: votre-domaine.com) dans la liste des domaines autorlés
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=votre_production_site_key
# RECAPTCHA_SECRET_KEY=votre_production_secret_key

# Google OAuth (obtenir sur https://console.cloud.google.com/apis/credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP / Email (pour l'envoi réel des liens de réinitialisation)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
EMAIL_FROM="JCI Ledger <no-reply@jci-ledger.tn>"
